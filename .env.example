# 你的 Telegram Bot 的 API Token。从 @BotFather 获取。
BOT_TOKEN=your_telegram_bot_token

# 文件存储的目标，可以是公开频道的 @username 或你自己的用户 ID。
CHANNEL_NAME=@your_telegram_channel_or_your_id

# [可选] 访问 Web 界面的密码。如果留空，则无需密码。
PASS_WORD=your_secret_password

# [可选] PicGo 上传接口的 API 密钥。如果留空，则无需密钥。
PICGO_API_KEY=your_picgo_api_key

# [可选] 你的服务的公开访问 URL，用于生成完整的文件下载链接。
BASE_URL=http://127.0.0.1:8000

# [可选] Telegram MTProto 配置。启用后可同步群组内手动删除到网页前端。
TG_API_ID=123456
TG_API_HASH=your_telegram_api_hash

# [可选] MTProto 会话名、会话字符串与对账周期（秒）。
TELEGRAM_SYNC_SESSION=tgstate-sync
TELEGRAM_SYNC_SESSION_STRING=
TELEGRAM_RECONCILE_INTERVAL=60
